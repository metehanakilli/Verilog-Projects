set_property LOC BUFGCTRL_X0Y2 [get_cells clock_divider_wclk_inst/CLK_BUFG_inst]
set_property LOC BUFGCTRL_X0Y0 [get_cells clock_divider_rclk_inst/CLK_BUFG_inst]
